{% assign product = product %}
{% assign selected_variant = product.selected_or_first_available_variant %}
{% comment %}
  variant.available can be false while admin still shows quantity (e.g. multi-location / fulfillment mismatch).
  We also treat as sellable when policy is continue, inventory_quantity is positive, or stock is not tracked.
{% endcomment %}
{% assign selected_sellable = false %}
{% if selected_variant.available %}
  {% assign selected_sellable = true %}
{% endif %}
{% unless selected_sellable %}
  {% if selected_variant.inventory_policy == 'continue' %}
    {% assign selected_sellable = true %}
  {% elsif selected_variant.inventory_quantity > 0 %}
    {% assign selected_sellable = true %}
  {% elsif selected_variant.inventory_management == blank %}
    {% assign selected_sellable = true %}
  {% endif %}
{% endunless %}
{% assign main_image = selected_variant.featured_image | default: product.featured_image %}

<div class="product-page" data-product-page>
  <div class="product-page__gallery">
    {% if main_image %}
      <img
        id="product-main-image"
        class="product-page__main-img"
        src="{{ main_image | image_url: width: 1200 }}"
        alt="{{ main_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {% else %}
      <div style="aspect-ratio:1;background:var(--bg);display:flex;align-items:center;justify-content:center;border:0.5px solid var(--line)">
        <svg width="80" height="80" viewBox="0 0 64 64" style="opacity:0.1;fill:var(--navy)"><path d="M20 8c0 0 4 20 4 32s-4 16-4 16M28 6c0 0 4 22 4 34s-4 16-4 16M36 8c0 0 4 20 4 32s-4 16-4 16M44 10c0 0 4 18 4 30s-4 16-4 16"/></svg>
      </div>
    {% endif %}
    {% if product.images.size > 1 %}
      <div class="product-page__thumbs" role="list" aria-label="Product images">
        {% for image in product.images %}
          <button
            type="button"
            class="product-page__thumb{% if main_image and image.id == main_image.id %} is-active{% endif %}"
            role="listitem"
            data-full-src="{{ image | image_url: width: 1200 }}"
            data-image-alt="{{ image.alt | escape }}"
            aria-label="View product image {{ forloop.index }}"
          >
            <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}" loading="lazy" width="200" height="200">
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="product-page__info">
    <div class="product-page__vendor">{{ product.vendor }}</div>
    <h1 class="product-page__title">{{ product.title }}</h1>
    <div class="product-page__price">{{ product.price | money }}</div>

    {% unless product.has_only_default_variant %}
      {% for option in product.options_with_values %}
        <div class="product-page__label">{{ option.name }}</div>
        <div class="product-page__variants">
          {% for value in option.values %}
            {% assign is_active = false %}
            {% case option.position %}
              {% when 1 %}
                {% if value == selected_variant.option1 %}{% assign is_active = true %}{% endif %}
              {% when 2 %}
                {% if value == selected_variant.option2 %}{% assign is_active = true %}{% endif %}
              {% when 3 %}
                {% if value == selected_variant.option3 %}{% assign is_active = true %}{% endif %}
            {% endcase %}
            <button type="button" class="variant-btn{% if is_active %} active{% endif %}" data-option-index="{{ option.position | minus: 1 }}" data-value="{{ value | escape }}">
              {{ value }}
            </button>
          {% endfor %}
        </div>
      {% endfor %}
    {% endunless %}

    <div class="product-page__label" style="margin-top:16px">Quantity</div>
    <div class="product-page__qty">
      <button class="qty-btn" data-action="minus">−</button>
      <input type="number" class="qty-input" value="1" min="1">
      <button class="qty-btn" data-action="plus">+</button>
    </div>

    <form action="/cart/add" method="post" enctype="multipart/form-data" id="product-form-add">
      <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-input>
      <input type="hidden" name="quantity" value="1">
      <button type="submit" class="btn btn--gold btn--full" style="margin-bottom:12px" data-add-to-cart {% unless selected_sellable %}disabled aria-disabled="true"{% endunless %}>
        {% if selected_sellable %}Add to Cart{% else %}Out of Stock{% endif %}
      </button>
    </form>

    <a href="{% render 'theme-contact-url' %}" class="btn btn--ghost-dark btn--full" style="border-color:var(--line2);color:var(--muted)">
      Enquire on WhatsApp
    </a>

    <div style="margin-top:28px;padding-top:24px;border-top:0.5px solid var(--line)">
      <div class="product-page__desc">{{ product.description }}</div>
    </div>

    <div style="margin-top:24px;padding:16px;background:var(--off);border:0.5px solid var(--line)">
      <div style="font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);margin-bottom:10px">Delivery</div>
      <div style="font-size:13px;color:var(--muted);line-height:1.7">Same-day Lagos dispatch before 12pm. All 36 states via GIG Logistics and DHL. WhatsApp tracking on every order.</div>
    </div>
  </div>
</div>

<script type="application/json" id="product-variants-data">
[
{%- for variant in product.variants -%}
  {%- assign v_sellable = false -%}
  {%- if variant.available -%}
    {%- assign v_sellable = true -%}
  {%- endif -%}
  {%- unless v_sellable -%}
    {%- if variant.inventory_policy == 'continue' -%}
      {%- assign v_sellable = true -%}
    {%- elsif variant.inventory_quantity > 0 -%}
      {%- assign v_sellable = true -%}
    {%- elsif variant.inventory_management == blank -%}
      {%- assign v_sellable = true -%}
    {%- endif -%}
  {%- endunless -%}
  {"id":{{ variant.id }},"option1":{{ variant.option1 | json }},"option2":{{ variant.option2 | json }},"option3":{{ variant.option3 | json }},"available":{{ v_sellable | json }},"image":{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 1200 | json }}{% else %}null{% endif %}}
  {%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
</script>
