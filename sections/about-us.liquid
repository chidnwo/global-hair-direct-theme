{% liquid
  assign check_count = 0
  for block in section.blocks
    if block.type == 'check_item'
      assign check_count = check_count | plus: 1
    endif
  endfor

  capture default_contact_url
    render 'theme-contact-url'
  endcapture
  assign default_contact_url = default_contact_url | strip
%}
<section class="section about-us about-us--compact" id="about" data-about-section>
  <div class="about-us__inner about-us__inner--single">
    <div class="about-us__story">
      <div class="eyebrow">
        <div class="eyebrow__line"></div>
        <span class="eyebrow__text">{{ section.settings.left_eyebrow | default: 'About Us' }}</span>
      </div>
      <h2 class="section__title about-us__title">
        {{ section.settings.title | default: 'Built for' }}
        <em>{{ section.settings.title_italic | default: 'how you buy hair.' }}</em>
      </h2>
      <p class="section__lead about-us__lead">{{ section.settings.lead | default: 'We supply braiding, bulk, and curl lines to salons, distributors, and individual buyers across Nigeria — with written pricing before you pay, colour runs you can trust, and delivery you can track.' }}</p>

      <ul class="about-us__checks">
        {% if check_count > 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'check_item' %}
              <li class="about-us__check{% if block.settings.is_negative %} about-us__check--no{% endif %}" {{ block.shopify_attributes }}>
                <span class="about-us__check-icon" aria-hidden="true">{% if block.settings.is_negative %}✕{% else %}✓{% endif %}</span>
                <div class="about-us__check-body">
                  <strong>{{ block.settings.label }}</strong>
                  {{ block.settings.text }}
                </div>
              </li>
            {% endif %}
          {% endfor %}
        {% else %}
          <li class="about-us__check">
            <span class="about-us__check-icon" aria-hidden="true">✓</span>
            <div class="about-us__check-body"><strong>Who we serve:</strong> Salon owners, distributors, and individual buyers in all 36 states.</div>
          </li>
          <li class="about-us__check">
            <span class="about-us__check-icon" aria-hidden="true">✓</span>
            <div class="about-us__check-body"><strong>What you get:</strong> Consistent grading, multiple colours per line, and wholesale tiers when you order regularly.</div>
          </li>
          <li class="about-us__check about-us__check--no">
            <span class="about-us__check-icon" aria-hidden="true">✕</span>
            <div class="about-us__check-body"><strong>What we avoid:</strong> Unconfirmed orders, colour substitutions without approval, or shipping outside Nigeria.</div>
          </li>
        {% endif %}
      </ul>

      {% if section.settings.show_cta %}
        <a href="{{ section.settings.cta_url | default: default_contact_url }}" class="btn btn--navy about-us__cta">
          {{ section.settings.cta_text | default: 'Request Wholesale Account' }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Us",
  "settings": [
    { "type": "text", "id": "left_eyebrow", "label": "Eyebrow", "default": "About Us" },
    { "type": "text", "id": "title", "label": "Title", "default": "Built for" },
    { "type": "text", "id": "title_italic", "label": "Title Italic", "default": "how you buy hair." },
    { "type": "textarea", "id": "lead", "label": "Lead Text" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA button", "default": true },
    { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Request Wholesale Account" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "blocks": [
    {
      "type": "check_item",
      "name": "Checklist Item",
      "settings": [
        { "type": "checkbox", "id": "is_negative", "label": "Negative item", "default": false },
        { "type": "text", "id": "label", "label": "Label", "default": "Who we serve:" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Salon owners, distributors, and individual buyers in all 36 states." }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Us",
      "blocks": [
        { "type": "check_item", "settings": { "is_negative": false, "label": "Who we serve:", "text": "Salon owners, distributors, and individual buyers in all 36 states." } },
        { "type": "check_item", "settings": { "is_negative": false, "label": "What you get:", "text": "Consistent grading, multiple colours per line, and wholesale tiers when you order regularly." } },
        { "type": "check_item", "settings": { "is_negative": true, "label": "What we avoid:", "text": "Unconfirmed orders, colour substitutions without approval, or shipping outside Nigeria." } }
      ]
    }
  ]
}
{% endschema %}
