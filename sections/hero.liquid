{% liquid
  assign stats_cat = collections[section.settings.stats_collection]
  assign hero_units = 0
  assign hero_types_count = 0
  assign hero_in_stock = 0
  assign hero_pre = 0
  assign hero_show_live = false
  if section.settings.use_live_catalog_stats and stats_cat != blank
    assign hero_show_live = true
    assign hero_types = stats_cat.products | map: 'type' | uniq
    for t in hero_types
      if t != blank
        assign hero_types_count = hero_types_count | plus: 1
      endif
    endfor
    for product in stats_cat.products limit: 250
      if product.tags contains 'pre-order'
        assign hero_pre = hero_pre | plus: 1
      elsif product.available
        assign hero_in_stock = hero_in_stock | plus: 1
      endif
      for variant in product.variants
        assign q = variant.inventory_quantity | default: 0
        assign hero_units = hero_units | plus: q
      endfor
    endfor
  endif
%}
<section class="hero">
  <div class="hero__content">
    <div class="hero__eyebrow">
      <div class="hero__eyebrow-line"></div>
      <span class="hero__eyebrow-text">{{ section.settings.eyebrow | default: "Nigeria's Hair Supplier" }}</span>
    </div>

    <h1 class="hero__title">{{ section.settings.title | default: "Quality You Can Trust." | newline_to_br }}<br><em>{{ section.settings.title_italic | default: 'From Supplier to Door.' }}</em></h1>

    <p class="hero__lead">{{ section.settings.lead | default: 'Global Hair Direct supplies braiding hair, bulk hair, and premium hair extensions directly to salon owners, distributors, and individual buyers across all 36 Nigerian states.' }}</p>

    <p class="hero__tagline">{{ section.settings.tagline | default: 'Transparent pricing. Accountable delivery.' }}</p>

    <div class="hero__actions">
      <a href="{{ section.settings.cta1_url | default: '/collections/all' }}" class="btn btn--gold">{{ section.settings.cta1_text | default: 'Place Pre-Order' }}</a>
      <a href="{{ section.settings.cta2_url | default: '/collections/all' }}" class="btn btn--white">{{ section.settings.cta2_text | default: 'View Catalogue' }}</a>
      <a href="{{ section.settings.cta3_url | default: '/pages/wholesale' }}" class="btn btn--ghost-light">{{ section.settings.cta3_text | default: 'Wholesale Inquiry' }}</a>
    </div>

  </div>

  <div class="hero__panel">
    <div class="hero__panel-head">
      <span class="hero__panel-title">{{ section.settings.panel_title | default: 'Current Stock' }}</span>
      <div class="hero__panel-live">
        <div class="hero__panel-dot"></div>
        {% if hero_show_live %}Live from catalogue{% else %}Updated today{% endif %}
      </div>
    </div>

    <div class="hero__stats">
      {% if hero_show_live %}
        <div class="hero__stat">
          <div class="hero__stat-val">{{ hero_units }}</div>
          <div class="hero__stat-lbl">Units in catalogue</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-val">{{ hero_types_count }}</div>
          <div class="hero__stat-lbl">Product types</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-val">{{ hero_in_stock }}</div>
          <div class="hero__stat-lbl">In stock now</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-val">{{ hero_pre }}</div>
          <div class="hero__stat-lbl">Pre-order lines</div>
        </div>
      {% else %}
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div class="hero__stat" {{ block.shopify_attributes }}>
              <div class="hero__stat-val">{{ block.settings.value }}</div>
              <div class="hero__stat-lbl">{{ block.settings.label }}</div>
            </div>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>

    <div class="hero__panel-notice">
      <div class="hero__panel-notice-tag">{{ section.settings.notice_tag | default: 'Pre-Order Offer — Active Now' }}</div>
      <p>{{ section.settings.notice_text | default: 'Bone Straight, French Curl & Deep Wave — order now and receive 5% discount on your total.' }}</p>
      <a href="{{ section.settings.notice_cta_url | default: '/collections/all' }}" class="btn btn--gold btn--full" style="margin-top:14px;height:38px;font-size:11px;">
        {{ section.settings.notice_cta_text | default: 'Place Pre-Order' }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Nigeria's Hair Supplier" },
    { "type": "textarea", "id": "title", "label": "Hero Title", "default": "Quality You Can Trust." },
    { "type": "text", "id": "title_italic", "label": "Title Italic Line", "default": "From Supplier to Door." },
    { "type": "textarea", "id": "lead", "label": "Lead Paragraph" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Transparent pricing. Accountable delivery." },
    { "type": "text", "id": "cta1_text", "label": "CTA 1 Text", "default": "Place Pre-Order" },
    { "type": "url", "id": "cta1_url", "label": "CTA 1 URL" },
    { "type": "text", "id": "cta2_text", "label": "CTA 2 Text", "default": "View Catalogue" },
    { "type": "url", "id": "cta2_url", "label": "CTA 2 URL" },
    { "type": "text", "id": "cta3_text", "label": "CTA 3 Text", "default": "Wholesale Inquiry" },
    { "type": "url", "id": "cta3_url", "label": "CTA 3 URL" },
    { "type": "text", "id": "panel_title", "label": "Panel Title", "default": "Current Stock" },
    { "type": "text", "id": "notice_tag", "label": "Notice Tag", "default": "Pre-Order Offer — Active Now" },
    { "type": "textarea", "id": "notice_text", "label": "Notice Text" },
    { "type": "text", "id": "notice_cta_text", "label": "Notice CTA Text", "default": "Place Pre-Order" },
    { "type": "url", "id": "notice_cta_url", "label": "Notice CTA URL" },
    { "type": "checkbox", "id": "use_live_catalog_stats", "label": "Use live stats from catalogue (collection)", "default": true },
    { "type": "collection", "id": "stats_collection", "label": "Catalogue for hero panel stats" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stats Panel Item",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "700+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Units in stock" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "stat", "settings": { "value": "700+", "label": "Units in stock" } },
        { "type": "stat", "settings": { "value": "3", "label": "Hair types" } },
        { "type": "stat", "settings": { "value": "36", "label": "States covered" } },
        { "type": "stat", "settings": { "value": "4+", "label": "Colour options" } }
      ]
    }
  ]
}
{% endschema %}
