<section class="section--dark buyer-tiers">
  <div class="buyer-tiers__inner">
    <div class="eyebrow eyebrow--gold">
      <div class="eyebrow__line"></div>
      <span class="eyebrow__text">{{ section.settings.eyebrow | default: 'Buyer Tiers' }}</span>
    </div>
    <h2 class="section__title section__title--light">{{ section.settings.title | default: 'Buy more.' }} <em>{{ section.settings.title_italic | default: 'Pay less.' }}</em></h2>
    {% assign bt_lead = section.settings.lead | strip %}
    {% if bt_lead != blank %}
      <p class="section__lead section__lead--light">{{ section.settings.lead }}</p>
    {% endif %}

    <div class="tier-rows">
      {% for block in section.blocks %}
        {% if block.type == 'tier' %}
          <article class="tier-row{% if block.settings.featured %} tier-row--featured{% endif %}" {{ block.shopify_attributes }}>
            <div class="tier-row__main">
              <p class="tier-row__num">{{ block.settings.tier_number }}</p>
              <h3 class="tier-row__name">
                {{ block.settings.name }}
                {% if block.settings.featured %}<span class="tier-row__flag">Most popular</span>{% endif %}
              </h3>
              {% assign tier_tagline = block.settings.tagline | strip %}
              {% if tier_tagline != blank %}
                <p class="tier-row__tagline">{{ tier_tagline }}</p>
              {% endif %}
            </div>
            <div class="tier-row__price">
              <span class="tier-row__disc">{{ block.settings.discount }}</span>
              <span class="tier-row__disc-lbl">{{ block.settings.discount_label }}</span>
            </div>
            {% if block.settings.cta_text != blank %}
              <a href="{{ block.settings.cta_url | default: '#' }}" class="tier-row__cta{% if block.settings.featured %} tier-row__cta--featured{% endif %}">
                {{ block.settings.cta_text }}
                <svg viewBox="0 0 16 16" width="13" height="13" aria-hidden="true"><path d="M3 8h9M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.footnote != blank %}
      <p class="buyer-tiers__footnote">{{ section.settings.footnote }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Buyer Tiers",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Buyer Tiers" },
    { "type": "text", "id": "title", "label": "Title", "default": "Buy more." },
    { "type": "text", "id": "title_italic", "label": "Title Italic", "default": "Pay less." },
    { "type": "textarea", "id": "lead", "label": "Lead Text", "default": "Three account tiers. The more you buy, the lower your per-unit price — confirmed in writing before any order." },
    { "type": "text", "id": "footnote", "label": "Footnote (small print under cards)", "default": "All pricing confirmed in writing. No hidden charges." }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier",
      "settings": [
        { "type": "text", "id": "tier_number", "label": "Tier Number", "default": "Tier 01" },
        { "type": "text", "id": "name", "label": "Tier Name", "default": "Salon / Stylist" },
        { "type": "text", "id": "discount", "label": "Discount (hero)", "default": "–15%" },
        { "type": "text", "id": "discount_label", "label": "Discount Label", "default": "Off retail pricing" },
        { "type": "text", "id": "tagline", "label": "Tagline (one short line)", "default": "Regular orders · priority dispatch" },
        { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Start Order" },
        { "type": "url", "id": "cta_url", "label": "CTA URL" },
        { "type": "checkbox", "id": "featured", "label": "Featured tier (highlight card)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Buyer Tiers",
      "blocks": [
        { "type": "tier", "settings": { "tier_number": "Tier 01", "name": "Salon / Stylist", "discount": "–15%", "discount_label": "Off retail pricing", "tagline": "Regular orders · priority dispatch", "cta_text": "Start Order", "cta_url": "/pages/wholesale-order", "featured": false } },
        { "type": "tier", "settings": { "tier_number": "Tier 02", "name": "Distributor", "discount": "–25%", "discount_label": "Off retail pricing", "tagline": "Bulk volume · dedicated support", "cta_text": "Start Order", "cta_url": "/pages/wholesale-order", "featured": true } },
        { "type": "tier", "settings": { "tier_number": "Tier 03", "name": "Master Distributor", "discount": "–35%", "discount_label": "Off retail pricing", "tagline": "Highest volume · lowest per-unit", "cta_text": "Start Order", "cta_url": "/pages/wholesale-order", "featured": false } }
      ]
    }
  ]
}
{% endschema %}
