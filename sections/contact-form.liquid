<section class="section contact-form-section">
  <div class="eyebrow">
    <div class="eyebrow__line"></div>
    <span class="eyebrow__text">{{ section.settings.eyebrow }}</span>
  </div>
  {% assign contact_lead = section.settings.lead | strip %}
  {% assign contact_title_italic = section.settings.title_italic | strip %}
  <h1 class="section__title informal-page__title">{{ section.settings.title }}{% if contact_title_italic != blank %} <em>{{ contact_title_italic }}</em>{% endif %}</h1>
  {% if contact_lead != blank %}
    <p class="section__lead informal-page__lead contact-form-section__lead">{{ section.settings.lead }}</p>
  {% endif %}

  {% if page.content != blank %}
    <div class="informal-page__body contact-form-section__page rte">{{ page.content }}</div>
  {% endif %}

  <div class="contact-form-section__form-wrap">
    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <p class="customer-page__success" role="status">{{ section.settings.success_message }}</p>
      {% else %}
        {% if form.errors %}
          <ul class="customer-page__errors">
            {% for field in form.errors %}
              <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
            {% endfor %}
          </ul>
        {% endif %}

        <div class="customer-form__field">
          <label for="ContactForm-name">Name</label>
          <input
            id="ContactForm-name"
            class="customer-form__input"
            type="text"
            name="contact[name]"
            autocomplete="name"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            required
          >
        </div>

        <div class="customer-form__field">
          <label for="ContactForm-email">Email</label>
          <input
            id="ContactForm-email"
            class="customer-form__input"
            type="email"
            name="contact[email]"
            autocomplete="email"
            spellcheck="false"
            autocapitalize="off"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            required
          >
        </div>

        <div class="customer-form__field">
          <label for="ContactForm-phone">Phone <span class="contact-form-section__optional">(optional)</span></label>
          <input
            id="ContactForm-phone"
            class="customer-form__input"
            type="tel"
            name="contact[phone]"
            autocomplete="tel"
            value="{% if form.phone %}{{ form.phone }}{% endif %}"
          >
        </div>

        <div class="customer-form__field">
          <label for="ContactForm-enquiry-type">{{ section.settings.enquiry_type_label }}</label>
          <select
            id="ContactForm-enquiry-type"
            class="customer-form__input"
            name="contact[enquiry_type]"
            autocomplete="off"
            required
          >
            <option value="" disabled {% if form.enquiry_type == blank %}selected{% endif %}>{{ section.settings.enquiry_type_placeholder }}</option>
            <option value="Wholesale or distributor" {% if form.enquiry_type == 'Wholesale or distributor' %}selected{% endif %}>{{ section.settings.option_wholesale }}</option>
            <option value="Individual retail" {% if form.enquiry_type == 'Individual retail' %}selected{% endif %}>{{ section.settings.option_individual }}</option>
            <option value="Salon or stylist" {% if form.enquiry_type == 'Salon or stylist' %}selected{% endif %}>{{ section.settings.option_salon }}</option>
            <option value="Order delivery or return" {% if form.enquiry_type == 'Order delivery or return' %}selected{% endif %}>{{ section.settings.option_order }}</option>
            <option value="Other or general" {% if form.enquiry_type == 'Other or general' %}selected{% endif %}>{{ section.settings.option_other }}</option>
          </select>
        </div>

        <div class="customer-form__field">
          <label for="ContactForm-reply-preference">{{ section.settings.reply_preference_label }} <span class="contact-form-section__optional">(optional)</span></label>
          <select
            id="ContactForm-reply-preference"
            class="customer-form__input"
            name="contact[reply_preference]"
            autocomplete="off"
          >
            <option value="" {% if form.reply_preference == blank %}selected{% endif %}>{{ section.settings.reply_preference_placeholder }}</option>
            <option value="Email" {% if form.reply_preference == 'Email' %}selected{% endif %}>Email</option>
            <option value="Phone" {% if form.reply_preference == 'Phone' %}selected{% endif %}>Phone</option>
            <option value="WhatsApp" {% if form.reply_preference == 'WhatsApp' %}selected{% endif %}>WhatsApp</option>
          </select>
        </div>

        <div class="customer-form__field">
          <label for="ContactForm-message">Message</label>
          <textarea
            id="ContactForm-message"
            class="customer-form__input customer-form__textarea"
            name="contact[body]"
            rows="6"
            required
          >{{ form.body }}</textarea>
        </div>

        <div class="customer-form__actions">
          <button type="submit" class="btn btn--gold btn--full">{{ section.settings.submit_label }}</button>
        </div>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "class": "section-contact-form",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Contact" },
    { "type": "text", "id": "title", "label": "Title", "default": "Contact us." },
    { "type": "text", "id": "title_italic", "label": "Title (italic part)", "info": "Clear this field in the theme editor to hide the italic line.", "default": "We are here to help." },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Short summary (intro)",
      "info": "Optional. Shown under the title, above the form. Clear this field to hide the intro paragraph.",
      "default": "Choose an enquiry type below so we can route your message to the right team."
    },
    {
      "type": "header",
      "content": "Enquiry type dropdown"
    },
    {
      "type": "text",
      "id": "enquiry_type_label",
      "label": "Enquiry type label",
      "default": "What are you contacting us about?"
    },
    {
      "type": "text",
      "id": "enquiry_type_placeholder",
      "label": "Enquiry type placeholder",
      "default": "Select an option"
    },
    {
      "type": "text",
      "id": "option_wholesale",
      "label": "Option: wholesale",
      "default": "Wholesale or distributor"
    },
    {
      "type": "text",
      "id": "option_individual",
      "label": "Option: individual",
      "default": "Individual (retail)"
    },
    {
      "type": "text",
      "id": "option_salon",
      "label": "Option: salon",
      "default": "Salon or stylist"
    },
    {
      "type": "text",
      "id": "option_order",
      "label": "Option: order / delivery",
      "default": "Order, delivery, or return"
    },
    {
      "type": "text",
      "id": "option_other",
      "label": "Option: other",
      "default": "Other / general"
    },
    {
      "type": "header",
      "content": "Reply preference dropdown"
    },
    {
      "type": "text",
      "id": "reply_preference_label",
      "label": "Reply preference label",
      "default": "How should we reply?"
    },
    {
      "type": "text",
      "id": "reply_preference_placeholder",
      "label": "Reply preference placeholder",
      "default": "No preference"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you — your message was sent. We will reply as soon as we can."
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Send message"
    }
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
