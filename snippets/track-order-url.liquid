{%- liquid
  assign track_url = ''
  if settings.track_order_page != blank
    assign _p = pages[settings.track_order_page]
    if _p != blank
      assign track_url = _p.url
    endif
  endif
  if track_url == blank and pages['track-order'] != blank
    assign track_url = pages['track-order'].url
  endif
  if track_url == blank
    assign _contact = pages['contact']
    if _contact != blank
      assign track_url = _contact.url
    endif
  endif
  if track_url == blank
    assign track_url = '/pages/contact'
  endif
  echo track_url
-%}
