{% comment %}
  Computes live catalogue stats from a collection (Shopify inventory on each request).
  Pass: ghd_stats_collection (collection object)
  Sets: ghd_live_in_stock, ghd_live_pre, ghd_total_units, ghd_sellable_sku_count,
        ghd_catalog_display_count, ghd_catalog_count_is_sku_fallback, ghd_types_count
{% endcomment %}
{% liquid
  assign ghd_live_in_stock = 0
  assign ghd_live_pre = 0
  assign ghd_total_units = 0
  assign ghd_sellable_sku_count = 0
  assign ghd_catalog_display_count = 0
  assign ghd_catalog_count_is_sku_fallback = false
  assign ghd_types_count = 0

  if ghd_stats_collection != blank
    assign ghd_catalog_types = ghd_stats_collection.products | map: 'type' | uniq
    for t in ghd_catalog_types
      if t != blank
        assign ghd_types_count = ghd_types_count | plus: 1
      endif
    endfor

    for product in ghd_stats_collection.products
      assign product_stats_sellable = false
      if product.available
        assign product_stats_sellable = true
      endif
      unless product_stats_sellable
        for variant in product.variants
          assign v_qty = variant.inventory_quantity | default: 0
          if variant.available or variant.inventory_policy == 'continue' or v_qty > 0 or variant.inventory_management == blank
            assign product_stats_sellable = true
            break
          endif
        endfor
      endunless
      if product.tags contains 'coming-soon' or product.tags contains 'out-of-stock'
        assign product_stats_sellable = false
      endif
      if product.tags contains 'pre-order'
        assign ghd_live_pre = ghd_live_pre | plus: 1
      elsif product_stats_sellable
        assign ghd_live_in_stock = ghd_live_in_stock | plus: 1
      endif
      for variant in product.variants
        assign v_qty = variant.inventory_quantity | default: 0
        if v_qty > 0
          assign ghd_total_units = ghd_total_units | plus: v_qty
        endif
        if variant.available or variant.inventory_policy == 'continue' or v_qty > 0 or variant.inventory_management == blank
          assign ghd_sellable_sku_count = ghd_sellable_sku_count | plus: 1
        endif
      endfor
    endfor

    assign ghd_catalog_display_count = ghd_total_units
    if ghd_total_units < 1 and ghd_sellable_sku_count > 0
      assign ghd_catalog_display_count = ghd_sellable_sku_count
      assign ghd_catalog_count_is_sku_fallback = true
    endif
    if ghd_total_units < 1 and ghd_sellable_sku_count < 1 and ghd_live_in_stock > 0
      assign ghd_catalog_display_count = ghd_live_in_stock
      assign ghd_catalog_count_is_sku_fallback = true
    endif
  endif
%}
