<div
  class="cart-drawer"
  id="CartDrawer"
  data-cart-drawer
  data-money-format="{{ shop.money_format | escape }}"
  data-cart-url="{{ routes.cart_url }}"
  data-all-products-url="{{ routes.all_products_collection_url }}"
  hidden
>
  <div class="cart-drawer__backdrop" data-cart-drawer-close></div>
  <aside class="cart-drawer__panel" role="dialog" aria-modal="true" aria-label="Your cart">
    <header class="cart-drawer__head">
      <span class="cart-drawer__title">Your cart</span>
      <button type="button" class="cart-drawer__close" data-cart-drawer-close aria-label="Close cart">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12"/><path d="M18 6L6 18"/></svg>
      </button>
    </header>

    <div class="cart-drawer__body" data-cart-drawer-body aria-live="polite">
      <p class="cart-drawer__loading">Loading…</p>
    </div>

    <footer class="cart-drawer__foot" data-cart-drawer-foot hidden>
      <div class="cart-drawer__subtotal">
        <span>Subtotal</span>
        <span data-cart-drawer-subtotal></span>
      </div>
      <p class="cart-drawer__note">Delivery calculated at checkout.</p>
      <form action="{{ routes.cart_url }}" method="post">
        <button type="submit" name="checkout" class="btn btn--gold btn--full cart-drawer__checkout">Checkout</button>
      </form>
      <a href="{{ routes.cart_url }}" class="btn btn--full cart-drawer__view">View full cart</a>
    </footer>
  </aside>
</div>
