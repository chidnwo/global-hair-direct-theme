{% if section.settings.show_bar %}
<div class="announcement-bar">
  <div class="announcement-bar__track">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <span class="announcement-bar__item">{{ block.settings.text }}<span class="announcement-bar__sep"> · </span></span>
      {% endfor %}
      {% for block in section.blocks %}
        <span class="announcement-bar__item">{{ block.settings.text }}<span class="announcement-bar__sep"> · </span></span>
      {% endfor %}
    {% else %}
      <span class="announcement-bar__item">{{ section.settings.fallback_text }}<span class="announcement-bar__sep"> · </span></span>
      <span class="announcement-bar__item">{{ section.settings.fallback_text_secondary }}<span class="announcement-bar__sep"> · </span></span>
      <span class="announcement-bar__item">{{ section.settings.fallback_text_tertiary }}<span class="announcement-bar__sep"> · </span></span>
      <span class="announcement-bar__item">{{ section.settings.fallback_text }}<span class="announcement-bar__sep"> · </span></span>
      <span class="announcement-bar__item">{{ section.settings.fallback_text_secondary }}<span class="announcement-bar__sep"> · </span></span>
      <span class="announcement-bar__item">{{ section.settings.fallback_text_tertiary }}<span class="announcement-bar__sep"> · </span></span>
    {% endif %}
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "checkbox", "id": "show_bar", "label": "Show Announcement Bar", "default": true },
    { "type": "text", "id": "fallback_text", "label": "Fallback Text", "default": "Same-Day Lagos Dispatch on Confirmed Orders" },
    { "type": "text", "id": "fallback_text_secondary", "label": "Fallback Text 2", "default": "Pre-Order Open: Get 5% Off All Hair Types" },
    { "type": "text", "id": "fallback_text_tertiary", "label": "Fallback Text 3", "default": "Wholesale Pricing Available for Salons & Distributors" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Announcement Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Bone Straight Braiding Hair — 30inch" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "item", "settings": { "text": "Bone Straight Braiding Hair — 30inch" } },
        { "type": "item", "settings": { "text": "French Curl Hair — 22inch" } },
        { "type": "item", "settings": { "text": "Deep Wave Bulk — 22inch" } },
        { "type": "item", "settings": { "text": "Colours: 1B · 27# · BUG · 613#" } },
        { "type": "item", "settings": { "text": "Wholesale Orders Welcome" } },
        { "type": "item", "settings": { "text": "Pre-Order Open: Get 5% Off All Hair Types" } },
        { "type": "item", "settings": { "text": "Wholesale Pricing Available for Salons & Distributors" } },
        { "type": "item", "settings": { "text": "Same-Day Lagos Dispatch on Confirmed Orders" } },
        { "type": "item", "settings": { "text": "All 36 States Covered" } }
      ]
    }
  ]
}
{% endschema %}
