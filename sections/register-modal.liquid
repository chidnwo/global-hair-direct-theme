{% liquid
  assign on_register_page = false
  assign reg_path = request.path | default: ''
  if reg_path contains 'account/register'
    assign on_register_page = true
  endif
%}
{% if section.settings.enable and on_register_page == false %}
  {% unless section.settings.hide_for_logged_in and customer %}
    <div
      id="register-modal-{{ section.id }}"
      class="welcome-popup register-modal"
      hidden
      data-register-modal
    >
      <div class="welcome-popup__backdrop" data-register-modal-close tabindex="-1" aria-hidden="true"></div>
      <div
        class="welcome-popup__dialog register-modal__dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="register-modal-title-{{ section.id }}"
        aria-describedby="register-modal-desc-{{ section.id }}"
      >
        <button
          type="button"
          class="welcome-popup__close"
          data-register-modal-close
          aria-label="{{ section.settings.close_label | escape }}"
        >
          <span aria-hidden="true">&times;</span>
        </button>

        {% if section.settings.heading != blank %}
          <h2 id="register-modal-title-{{ section.id }}" class="welcome-popup__title register-modal__title">{{ section.settings.heading | escape }}</h2>
        {% endif %}
        {% if section.settings.lead != blank %}
          <p id="register-modal-desc-{{ section.id }}" class="welcome-popup__lead register-modal__lead">{{ section.settings.lead | escape }}</p>
        {% endif %}

        {% form 'create_customer', id: 'RegisterModalForm', class: 'welcome-popup__form register-modal__form', return_to: routes.account_url %}
          {% if form.errors %}
            <ul class="customer-page__errors welcome-popup__errors" role="alert">
              {% for field in form.errors %}
                <li>
                  {{ form.errors.translated_fields[field] | default: field | capitalize }}
                  {{ form.errors.messages[field] }}
                </li>
              {% endfor %}
            </ul>
          {% endif %}

          <fieldset class="customer-form__field register-form__fieldset register-modal__fieldset">
            <legend class="register-form__legend">{{ section.settings.account_type_label | default: 'I am registering as' | escape }}</legend>
            <div class="register-form__account-type register-modal__account-type">
              <label class="register-form__radio register-modal__radio-pill">
                <input type="radio" name="customer[note]" value="Buyer type: Individual buyer" required>
                <span>{{ section.settings.label_individual | default: 'Individual buyer' | escape }}</span>
              </label>
              <label class="register-form__radio register-modal__radio-pill">
                <input type="radio" name="customer[note]" value="Buyer type: Salon">
                <span>{{ section.settings.label_salon | default: 'Salon' | escape }}</span>
              </label>
              <label class="register-form__radio register-modal__radio-pill">
                <input type="radio" name="customer[note]" value="Buyer type: Wholesale / distributor">
                <span>{{ section.settings.label_wholesale | default: 'Wholesale / distributor' | escape }}</span>
              </label>
            </div>
          </fieldset>

          <div class="register-modal__grid-2">
            <div class="customer-form__field register-modal__field-tight">
              <label for="RegisterModal-FirstName">First name</label>
              <input id="RegisterModal-FirstName" class="customer-form__input" type="text" name="customer[first_name]" autocomplete="given-name" value="{{ form.first_name }}">
            </div>
            <div class="customer-form__field register-modal__field-tight">
              <label for="RegisterModal-LastName">Last name</label>
              <input id="RegisterModal-LastName" class="customer-form__input" type="text" name="customer[last_name]" autocomplete="family-name" value="{{ form.last_name }}">
            </div>
          </div>
          <div class="customer-form__field register-modal__field-tight">
            <label for="RegisterModal-Email">Email</label>
            <input id="RegisterModal-Email" class="customer-form__input" type="email" name="customer[email]" autocomplete="email" required value="{{ form.email }}">
          </div>
          <div class="customer-form__field register-modal__field-tight">
            <label for="RegisterModal-Phone">Phone</label>
            <input id="RegisterModal-Phone" class="customer-form__input" type="tel" name="customer[phone]" autocomplete="tel" inputmode="tel" value="{{ form.phone }}">
          </div>
          <div class="register-modal__grid-2">
            <div class="customer-form__field register-modal__field-tight">
              <label for="RegisterModal-Password">Password</label>
              <input id="RegisterModal-Password" class="customer-form__input" type="password" name="customer[password]" autocomplete="new-password" required>
            </div>
            <div class="customer-form__field register-modal__field-tight">
              <label for="RegisterModal-PasswordConfirm">Confirm</label>
              <input id="RegisterModal-PasswordConfirm" class="customer-form__input" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
            </div>
          </div>

          <div class="customer-form__actions register-modal__actions">
            <button type="submit" class="btn btn--gold btn--full">{{ section.settings.submit_label | escape }}</button>
            <a class="customer-form__link" href="{{ routes.storefront_login_url }}" style="text-align:center">{{ section.settings.login_link_label | escape }}</a>
          </div>
        {% endform %}

        {% if section.settings.fine_print != blank %}
          <p class="welcome-popup__fine register-modal__fine">{{ section.settings.fine_print | escape }}</p>
        {% endif %}
      </div>
    </div>
  {% endunless %}
{% endif %}

{% schema %}
{
  "name": "Register modal",
  "tag": "section",
  "class": "section-register-modal",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable register modal",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_for_logged_in",
      "label": "Hide for logged-in customers",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create account"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Short description",
      "default": "Pick a buyer type and add your details. Wholesale & salon rates may need approval first."
    },
    {
      "type": "text",
      "id": "account_type_label",
      "label": "Account type section label",
      "default": "I am registering as"
    },
    {
      "type": "text",
      "id": "label_individual",
      "label": "Option — Individual",
      "default": "Individual buyer"
    },
    {
      "type": "text",
      "id": "label_salon",
      "label": "Option — Salon",
      "default": "Salon"
    },
    {
      "type": "text",
      "id": "label_wholesale",
      "label": "Option — Wholesale",
      "default": "Wholesale / distributor"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button",
      "default": "Create account"
    },
    {
      "type": "text",
      "id": "login_link_label",
      "label": "Link to log in",
      "default": "Already have an account? Log in"
    },
    {
      "type": "text",
      "id": "close_label",
      "label": "Close button (screen readers)",
      "default": "Close"
    },
    {
      "type": "textarea",
      "id": "fine_print",
      "label": "Fine print (optional)",
      "default": "Your selection is saved on your customer profile for our team. Pricing tiers still follow approval and order history where applicable."
    }
  ],
  "presets": [{ "name": "Register modal" }]
}
{% endschema %}
