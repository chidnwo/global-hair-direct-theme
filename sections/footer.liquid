<footer class="site-footer">
  <div class="site-footer__grid">
    <div>
      <div class="site-footer__brand">
        <div class="site-footer__logo-mark">
          <svg viewBox="0 0 16 16"><path d="M8 1C4.1 1 1 4.1 1 8s3.1 7 7 7 7-3.1 7-7-3.1-7-7-7zm0 3c.8 0 1.4.6 1.4 1.4S8.8 6.8 8 6.8 6.6 6.2 6.6 5.4 7.2 4 8 4zm0 8.5c-1.8 0-3.3-.8-4.3-2.1.6-.8 3-1.3 4.3-1.3s3.7.5 4.3 1.3c-1 1.3-2.5 2.1-4.3 2.1z"/></svg>
        </div>
        <span class="site-footer__brand-name">{{ section.settings.brand_name | default: shop.name }}</span>
      </div>
      <p class="site-footer__desc">{{ section.settings.desc | default: 'Quality hair supply for salon owners, distributors, and individual buyers across all 36 Nigerian states. Braiding hair, bulk hair, and premium extensions - delivered direct.' }}</p>
      {% assign instagram_url = section.settings.social_instagram | default: 'https://www.instagram.com/globalhairdirectng/' %}
      {% if instagram_url != blank %}
        <div class="site-footer__social">
          <a href="{{ instagram_url }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram @globalhairdirectng">
            <svg class="site-footer__social-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.441 1.441 1.441c.795 0 1.439-.645 1.439-1.441s-.644-1.44-1.439-1.44z"/></svg>
            <span>@globalhairdirectng</span>
          </a>
        </div>
      {% endif %}
    </div>
    <div class="site-footer__col">
      <h5>Products</h5>
      <a href="#">Bone Straight 30inch</a>
      <a href="#">French Curl 22inch</a>
      <a href="#">Deep Wave Bulk</a>
      <a href="/pages/common-questions">Common Questions</a>
      <a href="{% render 'theme-contact-url' %}">Contact Us</a>
    </div>
    <div class="site-footer__col">
      <h5>Accounts</h5>
      <a href="#">Wholesale</a>
      <a href="#">Pre-Order</a>
      <a href="#">Salon Registration</a>
      <a href="#">Distributor Access</a>
      <a href="#">Referral Programme</a>
    </div>
    <div class="site-footer__col">
      <h5>Support</h5>
      <a href="#">WhatsApp Team</a>
      <a href="#">Track My Order</a>
      <a href="#">Return Policy</a>
      <a href="#">Terms of Sale</a>
      <a href="#">Privacy Policy</a>
    </div>
  </div>

  <div class="site-footer__bottom">
    <span class="site-footer__copy">© {{ 'now' | date: '%Y' }} {{ shop.name }} · All rights reserved · {{ section.settings.email }}</span>
    <div class="site-footer__payments">
      <span class="payment-badge">Paystack</span>
      <span class="payment-badge">Flutterwave</span>
      <span class="payment-badge">Bank Transfer</span>
      <span class="payment-badge">USSD</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand Name", "default": "Global Hair Direct Nigeria" },
    { "type": "textarea", "id": "desc", "label": "Brand Description" },
    { "type": "text", "id": "email", "label": "Contact Email", "default": "info@globalhairdirect.com.ng" },
    { "type": "header", "content": "Social media" },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram",
      "info": "Use your full profile URL. Handle @globalhairdirectng → instagram.com/globalhairdirectng"
    }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
