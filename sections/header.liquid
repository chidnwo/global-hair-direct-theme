<div class="site-header">
  <a href="/" class="site-header__logo">
    <div class="site-header__logo-mark">
      <svg viewBox="0 0 16 16"><path d="M8 1C4.1 1 1 4.1 1 8s3.1 7 7 7 7-3.1 7-7-3.1-7-7-7zm0 3c.8 0 1.4.6 1.4 1.4S8.8 6.8 8 6.8 6.6 6.2 6.6 5.4 7.2 4 8 4zm0 8.5c-1.8 0-3.3-.8-4.3-2.1.6-.8 3-1.3 4.3-1.3s3.7.5 4.3 1.3c-1 1.3-2.5 2.1-4.3 2.1z"/></svg>
    </div>
    <div class="site-header__logo-text">
      <span class="site-header__logo-main">{{ section.settings.logo_text | default: shop.name }}</span>
      <span class="site-header__logo-sub">{{ section.settings.logo_sub | default: 'Nigeria' }}</span>
    </div>
  </a>

  <nav class="site-header__nav">
    {% for link in linklists[section.settings.menu].links %}
      <a href="{{ link.url }}" class="site-header__nav-link {% if link.active %}active{% endif %}">
        {{ link.title }}
      </a>
    {% endfor %}
  </nav>

  <div class="site-header__spacer"></div>
  <span class="site-header__flag">🇳🇬</span>
  <a href="{{ routes.cart_url }}" class="btn btn--navy" style="height:34px;font-size:12px;padding:0 16px;margin-right:10px;">
    Cart ({{ cart.item_count }})
  </a>
  <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="site-header__cta">
    {{ section.settings.cta_text | default: 'Pre-Order Now' }}
  </a>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Brand Name", "default": "Global Hair Direct" },
    { "type": "text", "id": "logo_sub", "label": "Sub text", "default": "Nigeria" },
    { "type": "link_list", "id": "menu", "label": "Navigation Menu", "default": "main-menu" },
    { "type": "text", "id": "cta_text", "label": "CTA Button Text", "default": "Pre-Order Now" },
    { "type": "url", "id": "cta_url", "label": "CTA Button URL" }
  ]
}
{% endschema %}
