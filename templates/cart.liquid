{% assign order_page_url = '/pages/wholesale-order' %}
{% if pages['wholesale-order'] != blank %}{% assign order_page_url = pages['wholesale-order'].url %}{% endif %}

<div class="cart-empty">
  <h1 class="cart-empty__title">Orders are placed by request</h1>
  <p class="cart-empty__text">Global Hair Direct is wholesale only — there is no checkout cart. Build your order by selecting the lines and quantities you need, and we confirm pricing in writing.</p>
  <a href="{{ order_page_url }}" class="btn btn--gold">Start Wholesale Order</a>
</div>

<script>
  (function () {
    window.setTimeout(function () {
      window.location.replace({{ order_page_url | json }});
    }, 2500);
  })();
</script>
