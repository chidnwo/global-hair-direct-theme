{% liquid
  assign og_title = page_title | default: shop.name
  assign og_description = page_description | default: shop.description | strip_html | truncate: 200
  assign og_url = canonical_url
  assign og_type = 'website'
  assign og_image = false

  if template.name == 'product' and product.featured_media and settings.social_share_use_product_image
    assign og_image = product.featured_media.preview_image
  elsif template.name == 'article' and article.image
    assign og_image = article.image
  elsif template.name == 'collection' and collection.featured_image
    assign og_image = collection.featured_image
  endif

  if og_image == false and settings.social_share_image != blank
    assign og_image = settings.social_share_image
  endif

  if template.name == 'product'
    assign og_type = 'product'
  elsif template.name == 'article'
    assign og_type = 'article'
  endif
%}
<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
{% if og_description != blank %}
  <meta property="og:description" content="{{ og_description | escape }}">
{% endif %}
<meta property="og:type" content="{{ og_type }}">
{% if og_image %}
  <meta property="og:image" content="{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
{% endif %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
{% if og_description != blank %}
  <meta name="twitter:description" content="{{ og_description | escape }}">
{% endif %}
{% if og_image %}
  <meta name="twitter:image" content="{{ og_image | image_url: width: 1200 }}">
{% endif %}
