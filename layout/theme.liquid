<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#2E0D14">
  <link rel="canonical" href="{{ canonical_url }}">
  <title>{{ page_title }} — {{ shop.name }}</title>
  {%- liquid
    assign meta_description = page_description
    if meta_description == blank
      assign meta_description = shop.description
    endif
  -%}
  {% if meta_description != blank %}<meta name="description" content="{{ meta_description | escape }}">{% endif %}
  {{ content_for_header }}
  {% render 'social-meta-tags' %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-{{ template.name }}">

  {% liquid
    assign ghd_sales_blocked = settings.store_coming_soon_mode
  %}

  {% liquid
    assign ghd_force_country_ng = false
    assign ghd_local_dev_host = false
    if request.host contains '127.0.0.1' or request.host contains 'localhost'
      assign ghd_local_dev_host = true
    endif
    unless settings.allow_visitor_detected_country
      unless request.design_mode
        if localization.country.iso_code != 'NG'
          if ghd_local_dev_host
            assign ghd_force_country_ng = true
          else
            for ghd_c in localization.available_countries
              if ghd_c.iso_code == 'NG'
                assign ghd_force_country_ng = true
                break
              endif
            endfor
          endif
        endif
      endunless
    endunless
  %}

  {% liquid
    assign ghd_local_theme_preview = false
    if request.host contains '127.0.0.1' or request.host contains 'localhost'
      assign ghd_local_theme_preview = true
    endif
  %}
  {% if ghd_local_theme_preview %}
    <div
      class="ghd-local-preview-bar"
      style="position:sticky;top:0;z-index:9999;background:#1a1a1a;color:#f5f5f5;font:12px/1.45 system-ui,-apple-system,sans-serif;padding:8px 12px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;border-bottom:1px solid #333;"
      role="region"
      aria-label="Local theme preview"
    >
      <strong style="letter-spacing:0.04em;text-transform:uppercase;font-size:10px;">Local preview</strong>
      <span style="opacity:0.9;">Inventory follows the selected country/market. If stock looks empty, choose <strong>NG</strong> (or your primary market) below.</span>
      {% if localization.available_countries.size > 0 %}
        {% form 'localization', id: 'ghd-dev-localization-form', class: 'ghd-local-preview-bar__form', return_to: request.path %}
          <label for="ghd-dev-country-select" style="clip:rect(0 0 0 0);clip-path:inset(50%);height:1px;width:1px;overflow:hidden;position:absolute;white-space:nowrap;">Country</label>
          <select
            id="ghd-dev-country-select"
            name="country_code"
            style="padding:5px 10px;border-radius:4px;border:1px solid #ccc;background:#fff;color:#111;max-width:min(320px,100vw);"
            onchange="this.form.submit()"
          >
            {% for country in localization.available_countries %}
              <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                {{ country.name }} ({{ country.iso_code }})
              </option>
            {% endfor %}
          </select>
        {% endform %}
      {% endif %}
    </div>
  {% endif %}

  {% section 'header' %}
  {% section 'announcement-bar' %}

  <main id="main-content">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}
  {% render 'cart-drawer' %}
  {% section 'welcome-popup' %}
  {% if settings.use_legacy_customer_auth %}
    {% section 'register-modal' %}
    {% section 'login-modal' %}
  {% endif %}

  {% if ghd_force_country_ng %}
    {% form 'localization', id: 'ghd-localization-default-ng', return_to: 'back' %}
      <input type="hidden" name="country_code" value="NG">
      <input type="hidden" name="language_code" value="{{ localization.language.iso_code }}">
    {% endform %}
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var f = document.getElementById('ghd-localization-default-ng');
        if (!f) return;
        if (window.Shopify && window.Shopify.country === 'NG') return;
        f.submit();
      });
    </script>
  {% endif %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
