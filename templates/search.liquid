<div class="collection-header">
  <div class="eyebrow">
    <div class="eyebrow__line"></div>
    <span class="eyebrow__text">Shop</span>
  </div>
  <h1 class="collection-header__title">Search</h1>
  <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__form">
    <input
      id="SearchPage-Input"
      class="customer-form__input search-page__input"
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="Search products..."
      autocomplete="off"
      aria-label="Search products"
    >
    <button type="submit" class="btn btn--navy btn--sm search-page__submit">Search</button>
  </form>
</div>

{% paginate search.results by 24 %}
  {% if search.performed %}
    {% if search.results_count > 0 %}
      <div class="collection-grid">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            {% assign product = item %}
            {% assign product_sellable = false %}
            {% for variant in product.variants %}
              {% assign v_qty = variant.inventory_quantity | default: 0 %}
              {% if variant.available or variant.inventory_policy == 'continue' or v_qty > 0 or variant.inventory_management == blank %}
                {% assign product_sellable = true %}
                {% break %}
              {% endif %}
            {% endfor %}
            {% if ghd_sales_blocked or product.tags contains 'coming-soon' or product.tags contains 'out-of-stock' %}
              {% assign product_sellable = false %}
            {% endif %}
            <a href="{{ product.url }}" class="product-card">
              <div class="product-card__image-wrap">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">
                {% else %}
                  <div class="product-card__image-placeholder">
                    <svg viewBox="0 0 64 64"><path d="M20 8c0 0 4 20 4 32s-4 16-4 16M28 6c0 0 4 22 4 34s-4 16-4 16M36 8c0 0 4 20 4 32s-4 16-4 16M44 10c0 0 4 18 4 30s-4 16-4 16"/></svg>
                  </div>
                {% endif %}
                {% if product_sellable %}
                  {% if product.tags contains 'pre-order' %}
                    <span class="product-card__badge product-card__badge--preorder">Pre-Order</span>
                  {% else %}
                    <span class="product-card__badge product-card__badge--instock">In Stock</span>
                  {% endif %}
                {% else %}
                  <span class="product-card__badge product-card__badge--soon">Coming Soon</span>
                {% endif %}
              </div>
              <div class="product-card__body">
                <div class="product-card__category">{{ product.type }}</div>
                <div class="product-card__title">{{ product.title }}</div>
                <div class="product-card__vendor">{{ product.vendor }}</div>
                <div class="product-card__footer">
                  <div>
                    <div class="product-card__price">{{ product.price | money }}</div>
                    <span class="product-card__price-label">Per unit</span>
                  </div>
                  <span class="product-card__cta-hint">View &amp; order</span>
                </div>
              </div>
            </a>
          {% else %}
            <a href="{{ item.url }}" class="product-card product-card--text">
              <div class="product-card__body">
                <div class="product-card__category product-card__category--type">{{ item.object_type }}</div>
                <div class="product-card__title">{{ item.title }}</div>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
      {% if paginate.pages > 1 %}
        <div class="collection-pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="btn btn--navy btn--sm">← Previous</a>
          {% endif %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="btn btn--navy btn--sm">Next →</a>
          {% endif %}
        </div>
      {% endif %}
    {% else %}
      <div class="search-state">
        <h2 class="search-state__title">No results for “{{ search.terms | escape }}”</h2>
        <p class="search-state__text">
          Check the spelling, try a more general word (for example “braiding”, “bulk”, or “curl”), or browse the full catalogue.
        </p>
        <div class="search-state__links">
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--gold">Browse the catalogue</a>
          <a href="/pages/contact" class="btn btn--navy">Ask us what you need</a>
        </div>
      </div>
    {% endif %}
  {% else %}
    <div class="search-state">
      <h2 class="search-state__title">Find your hair, fast.</h2>
      <p class="search-state__text">
        Search by product type, length, or colour — try “bone straight”, “deep wave”, or “613”. Or browse everything we stock.
      </p>
      <div class="search-state__links">
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--gold">Browse the catalogue</a>
      </div>
    </div>
  {% endif %}
{% endpaginate %}
