{% liquid
  assign order_collection = collections[section.settings.collection]
  assign use_live = false
  if order_collection != blank and order_collection.products_count > 0
    assign use_live = true
  endif
%}
<section class="section wholesale-order" data-wholesale-order>
  <div class="eyebrow">
    <div class="eyebrow__line"></div>
    <span class="eyebrow__text">{{ section.settings.eyebrow | default: 'Wholesale Order Request' }}</span>
  </div>
  {% assign wo_italic = section.settings.title_italic | strip %}
  <h1 class="section__title">{{ section.settings.title | default: 'Build Your Wholesale Order.' }}{% if wo_italic != blank %} <em>{{ wo_italic }}</em>{% endif %}</h1>
  {% if section.settings.lead != blank %}
    <p class="section__lead wholesale-order__lead">{{ section.settings.lead }}</p>
  {% endif %}

  <div class="contact-form-section__form-wrap wholesale-order__wrap">
    {% form 'contact', class: 'wholesale-order__form' %}
      {% if form.posted_successfully? %}
        <p class="customer-page__success" role="status">{{ section.settings.success_message }}</p>
      {% else %}
        {% if form.errors %}
          <ul class="customer-page__errors">
            {% for field in form.errors %}
              <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
            {% endfor %}
          </ul>
        {% endif %}

        {% comment %} ── Step 1: Select products + per-colour quantities ── {% endcomment %}
        <div class="wholesale-order__step">
          <div class="wholesale-order__step-head">
            <span class="wholesale-order__step-num">01</span>
            <div>
              <h2 class="wholesale-order__step-title">Select Products &amp; Quantities</h2>
              <p class="wholesale-order__step-text">Set the units for each colour you want — you can order the same product in several colours. {{ section.settings.moq_note }}</p>
            </div>
          </div>

          <div class="wholesale-order__lines">
            {% if use_live %}
              {% for product in order_collection.products %}
                {% assign line_label = product.title %}
                {% capture line_meta %}{{ product.type }}{% if product.vendor != blank %} · {{ product.vendor }}{% endif %}{% endcapture %}
                <div class="wholesale-line" data-line>
                  <div class="wholesale-line__head">
                    <span class="wholesale-line__name">{{ line_label }}</span>
                    {% assign meta_clean = line_meta | strip %}
                    {% if meta_clean != blank %}<span class="wholesale-line__meta">{{ meta_clean }}</span>{% endif %}
                  </div>
                  <div class="wholesale-line__colours">
                    {% for variant in product.variants %}
                      {% assign colour_label = variant.title %}
                      {% if product.has_only_default_variant %}{% assign colour_label = 'Units' %}{% endif %}
                      {% render 'wholesale-colour-input', line_label: line_label, colour_label: colour_label %}
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            {% else %}
              {% for block in section.blocks %}
                {% if block.type == 'product_line' %}
                  {% assign line_label = block.settings.title %}
                  <div class="wholesale-line" data-line {{ block.shopify_attributes }}>
                    <div class="wholesale-line__head">
                      <span class="wholesale-line__name">{{ line_label }}</span>
                      {% if block.settings.meta != blank %}<span class="wholesale-line__meta">{{ block.settings.meta }}</span>{% endif %}
                    </div>
                    <div class="wholesale-line__colours">
                      {% assign colours = block.settings.colours | strip %}
                      {% if colours != blank %}
                        {% assign colour_opts = colours | split: ',' %}
                        {% for c in colour_opts %}
                          {% assign c_clean = c | strip %}
                          {% if c_clean != blank %}
                            {% render 'wholesale-colour-input', line_label: line_label, colour_label: c_clean %}
                          {% endif %}
                        {% endfor %}
                      {% else %}
                        {% render 'wholesale-colour-input', line_label: line_label, colour_label: 'Units' %}
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>

          <div class="wholesale-order__summary" data-order-summary hidden>
            <span class="wholesale-order__summary-label">Your selection</span>
            <span class="wholesale-order__summary-value" data-summary-value>0 items · 0 units</span>
          </div>
          <p class="wholesale-order__empty" data-order-empty>Set a quantity on at least one colour to continue.</p>
        </div>

        {% comment %} ── Step 2: Business details ── {% endcomment %}
        <div class="wholesale-order__step">
          <div class="wholesale-order__step-head">
            <span class="wholesale-order__step-num">02</span>
            <div>
              <h2 class="wholesale-order__step-title">Your Business Details</h2>
              <p class="wholesale-order__step-text">We use these to confirm your tier pricing and prepare a written quote.</p>
            </div>
          </div>

          <div class="wholesale-order__saved" data-saved-wrap hidden>
            <label for="WholesaleOrder-saved">Load a saved business</label>
            <div class="wholesale-order__saved-row">
              <select id="WholesaleOrder-saved" class="customer-form__input" data-saved-select autocomplete="off">
                <option value="">Select a saved business…</option>
              </select>
              <button type="button" class="btn btn--ghost-dark wholesale-order__saved-clear" data-saved-clear>Clear saved</button>
            </div>
          </div>

          <div class="wholesale-order__grid">
            <div class="customer-form__field">
              <label for="WholesaleOrder-business">Business name</label>
              <input id="WholesaleOrder-business" class="customer-form__input" type="text" name="contact[Business name]" autocomplete="organization" required>
            </div>
            <div class="customer-form__field">
              <label for="WholesaleOrder-name">Contact name</label>
              <input id="WholesaleOrder-name" class="customer-form__input" type="text" name="contact[name]" autocomplete="name" value="{% if form.name %}{{ form.name }}{% endif %}" required>
            </div>
            <div class="customer-form__field">
              <label for="WholesaleOrder-email">Email</label>
              <input id="WholesaleOrder-email" class="customer-form__input" type="email" name="contact[email]" autocomplete="email" spellcheck="false" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% endif %}" required>
            </div>
            <div class="customer-form__field">
              <label for="WholesaleOrder-phone">Phone / WhatsApp</label>
              <input id="WholesaleOrder-phone" class="customer-form__input" type="tel" name="contact[phone]" autocomplete="tel" value="{{ form.phone }}" required>
            </div>
            <div class="customer-form__field">
              <label for="WholesaleOrder-tier">Buyer type</label>
              <select id="WholesaleOrder-tier" class="customer-form__input" name="contact[Buyer type]" autocomplete="off" required>
                <option value="" disabled selected>Select your buyer type</option>
                <option value="Wholesale distributor">Wholesale distributor</option>
                <option value="Salon / stylist">Salon / stylist</option>
                <option value="Reseller / retailer">Reseller / retailer</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="customer-form__field">
              <label for="WholesaleOrder-state">Delivery state / city</label>
              <input id="WholesaleOrder-state" class="customer-form__input" type="text" name="contact[Delivery location]" placeholder="e.g. Lagos, Abuja" required>
            </div>
            <div class="customer-form__field">
              <label for="WholesaleOrder-frequency">Order frequency <span class="contact-form-section__optional">(optional)</span></label>
              <select id="WholesaleOrder-frequency" class="customer-form__input" name="contact[Order frequency]" autocomplete="off">
                <option value="">No preference</option>
                <option value="One-off order">One-off order</option>
                <option value="Weekly reorders">Weekly reorders</option>
                <option value="Monthly reorders">Monthly reorders</option>
                <option value="Quarterly reorders">Quarterly reorders</option>
              </select>
            </div>
          </div>

          <div class="customer-form__field">
            <label for="WholesaleOrder-notes">Notes for your order <span class="contact-form-section__optional">(optional)</span></label>
            <textarea id="WholesaleOrder-notes" class="customer-form__input customer-form__textarea" name="contact[Notes]" rows="4" placeholder="Colour splits, target budget, delivery deadline, anything else we should know."></textarea>
          </div>

          <label class="wholesale-order__remember">
            <input type="checkbox" data-remember checked>
            <span>Remember my business details on this device for next time</span>
          </label>

          {% comment %} Hidden compiled order summary — populated by JS, included in the email body. {% endcomment %}
          <textarea name="contact[body]" data-order-body hidden>Wholesale order request</textarea>

          <div class="customer-form__actions">
            <button type="submit" class="btn btn--gold btn--full" data-order-submit>{{ section.settings.submit_label | default: 'Submit Order Request' }}</button>
            <p class="wholesale-order__disclaimer">{{ section.settings.disclaimer }}</p>
          </div>
        </div>
      {% endif %}
    {% endform %}
  </div>
</section>

<script>
  (function () {
    var root = document.querySelector('[data-wholesale-order]');
    if (!root) return;
    var form = root.querySelector('.wholesale-order__form');
    if (!form) return;

    var qtyInputs = Array.prototype.slice.call(root.querySelectorAll('[data-qty-input]'));
    var summaryWrap = root.querySelector('[data-order-summary]');
    var summaryValue = root.querySelector('[data-summary-value]');
    var emptyNote = root.querySelector('[data-order-empty]');
    var bodyField = root.querySelector('[data-order-body]');
    var submitBtn = root.querySelector('[data-order-submit]');

    var BUSINESS_FIELDS = {
      business: 'Business name',
      name: 'name',
      email: 'email',
      phone: 'phone',
      buyerType: 'Buyer type',
      location: 'Delivery location',
      frequency: 'Order frequency'
    };

    function field(name) { return form.querySelector('[name="contact[' + name + ']"]'); }
    function fieldVal(name) { var el = field(name); return el && el.value ? String(el.value).trim() : ''; }
    function setFieldVal(name, val) { var el = field(name); if (el) el.value = val || ''; }

    /* ── Order summary + email body ── */
    function refresh() {
      var unitTotal = 0, itemCount = 0, order = [], groups = {};
      qtyInputs.forEach(function (inp) {
        var q = parseInt(inp.value, 10) || 0;
        var stepper = inp.closest('[data-qty-stepper]');
        if (stepper) stepper.classList.toggle('is-active', q > 0);
        if (q < 1) return;
        itemCount++; unitTotal += q;
        var p = inp.getAttribute('data-line-name') || 'Item';
        var c = inp.getAttribute('data-colour-name') || '';
        if (!groups[p]) { groups[p] = []; order.push(p); }
        groups[p].push({ colour: c, qty: q });
      });

      if (summaryValue) {
        summaryValue.textContent = itemCount + (itemCount === 1 ? ' item · ' : ' items · ') + unitTotal + ' units';
      }
      if (summaryWrap) summaryWrap.hidden = itemCount === 0;
      if (emptyNote) emptyNote.hidden = itemCount > 0;

      if (bodyField) {
        var out = ['WHOLESALE ORDER REQUEST', ''];
        out.push('— BUSINESS —');
        out.push('Business: ' + (fieldVal('Business name') || '—'));
        out.push('Contact: ' + (fieldVal('name') || '—'));
        out.push('Email: ' + (fieldVal('email') || '—'));
        out.push('Phone / WhatsApp: ' + (fieldVal('phone') || '—'));
        out.push('Buyer type: ' + (fieldVal('Buyer type') || '—'));
        out.push('Delivery: ' + (fieldVal('Delivery location') || '—'));
        var freq = fieldVal('Order frequency');
        if (freq) out.push('Order frequency: ' + freq);
        out.push('');
        out.push('— ORDER LINES —');
        if (itemCount === 0) {
          out.push('(no quantities set yet)');
        } else {
          order.forEach(function (p) {
            out.push('• ' + p);
            groups[p].forEach(function (it) {
              var lbl = (it.colour && it.colour !== 'Units') ? it.colour : 'Qty';
              out.push('    - ' + lbl + ': ' + it.qty + ' units');
            });
          });
          out.push('');
          out.push('Total: ' + itemCount + (itemCount === 1 ? ' item, ' : ' items, ') + unitTotal + ' units across ' + order.length + (order.length === 1 ? ' product.' : ' products.'));
        }
        var notes = fieldVal('Notes');
        if (notes) { out.push(''); out.push('— NOTES —'); out.push(notes); }
        bodyField.value = out.join('\n');
      }
      return itemCount;
    }

    /* ── Quantity steppers ── */
    root.querySelectorAll('[data-qty-stepper]').forEach(function (stepper) {
      var input = stepper.querySelector('[data-qty-input]');
      if (!input) return;
      stepper.querySelectorAll('[data-qty-minus]').forEach(function (b) {
        b.addEventListener('click', function () {
          input.value = Math.max(0, (parseInt(input.value, 10) || 0) - 1);
          refresh();
        });
      });
      stepper.querySelectorAll('[data-qty-plus]').forEach(function (b) {
        b.addEventListener('click', function () {
          input.value = (parseInt(input.value, 10) || 0) + 1;
          refresh();
        });
      });
      input.addEventListener('input', refresh);
    });

    /* keep email body fresh as business details change */
    Object.keys(BUSINESS_FIELDS).forEach(function (k) {
      var el = field(BUSINESS_FIELDS[k]);
      if (el) el.addEventListener('input', refresh);
      if (el) el.addEventListener('change', refresh);
    });
    var notesEl = field('Notes');
    if (notesEl) notesEl.addEventListener('input', refresh);

    /* ── Saved business profiles (device localStorage; no login) ── */
    var SAVE_KEY = 'ghd_wholesale_profiles';
    var savedWrap = root.querySelector('[data-saved-wrap]');
    var savedSelect = root.querySelector('[data-saved-select]');
    var savedClear = root.querySelector('[data-saved-clear]');
    var rememberEl = root.querySelector('[data-remember]');

    function readProfiles() {
      try { return JSON.parse(window.localStorage.getItem(SAVE_KEY)) || []; }
      catch (e) { return []; }
    }
    function writeProfiles(list) {
      try { window.localStorage.setItem(SAVE_KEY, JSON.stringify(list)); } catch (e) {}
    }
    function profileLabel(p) {
      return p.business || p.email || p.name || 'Saved business';
    }
    function renderSavedOptions() {
      if (!savedSelect || !savedWrap) return;
      var profiles = readProfiles();
      savedSelect.innerHTML = '<option value="">Select a saved business…</option>';
      profiles.forEach(function (p, i) {
        var opt = document.createElement('option');
        opt.value = String(i);
        opt.textContent = profileLabel(p);
        savedSelect.appendChild(opt);
      });
      savedWrap.hidden = profiles.length === 0;
    }
    function applyProfile(p) {
      if (!p) return;
      Object.keys(BUSINESS_FIELDS).forEach(function (k) {
        if (p[k] != null) setFieldVal(BUSINESS_FIELDS[k], p[k]);
      });
      refresh();
    }
    function currentProfile() {
      var p = {};
      Object.keys(BUSINESS_FIELDS).forEach(function (k) { p[k] = fieldVal(BUSINESS_FIELDS[k]); });
      return p;
    }
    function persistProfile() {
      var p = currentProfile();
      if (!p.business && !p.email) return;
      var list = readProfiles().filter(function (x) {
        var sameBiz = (x.business || '').toLowerCase() === (p.business || '').toLowerCase();
        var sameEmail = (x.email || '').toLowerCase() === (p.email || '').toLowerCase();
        return !(sameBiz && sameEmail);
      });
      list.unshift(p);
      writeProfiles(list.slice(0, 8));
    }

    if (savedSelect) {
      savedSelect.addEventListener('change', function () {
        if (savedSelect.value === '') return;
        var profiles = readProfiles();
        applyProfile(profiles[parseInt(savedSelect.value, 10)]);
      });
    }
    if (savedClear) {
      savedClear.addEventListener('click', function () {
        try { window.localStorage.removeItem(SAVE_KEY); } catch (e) {}
        renderSavedOptions();
      });
    }
    renderSavedOptions();

    /* ── Submit ── */
    form.addEventListener('submit', function (e) {
      var count = refresh();
      if (count === 0) {
        e.preventDefault();
        if (emptyNote) {
          emptyNote.classList.add('wholesale-order__empty--error');
          emptyNote.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        return;
      }
      if (rememberEl && rememberEl.checked) persistProfile();
      // Only submit colours that have a quantity, so the email stays clean.
      qtyInputs.forEach(function (inp) {
        if ((parseInt(inp.value, 10) || 0) < 1) inp.disabled = true;
      });
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }
    });

    refresh();
  })();
</script>

{% schema %}
{
  "name": "Wholesale Order Builder",
  "tag": "section",
  "class": "section-wholesale-order",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Wholesale Order Request" },
    { "type": "text", "id": "title", "label": "Title", "default": "Build Your Wholesale Order." },
    { "type": "text", "id": "title_italic", "label": "Title (italic part)", "default": "Pick products. Set quantities." },
    { "type": "textarea", "id": "lead", "label": "Lead text", "default": "Select the lines you want to stock, set quantities per colour, and tell us your volumes. We confirm availability and your tier price in writing — no payment is taken here." },
    {
      "type": "collection",
      "id": "collection",
      "label": "Live catalogue collection",
      "info": "Optional. If set and it has products, the form lists those products and their colour variants automatically. Otherwise the manual Product Line blocks below are used."
    },
    { "type": "text", "id": "moq_note", "label": "MOQ note (under step 1)", "default": "Minimum order quantities are confirmed on your quote." },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer under submit button",
      "default": "This is a request, not a paid order. Our team replies with confirmed pricing, MOQs, and payment options."
    },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "Submit Order Request" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thank you — your wholesale order request was received. We will reply with a confirmed quote shortly." }
  ],
  "blocks": [
    {
      "type": "product_line",
      "name": "Product Line",
      "settings": [
        { "type": "text", "id": "title", "label": "Product name", "default": "Bone Straight Braiding Hair 30inch" },
        { "type": "text", "id": "meta", "label": "Spec / description", "default": "150g · Braiding Hair" },
        { "type": "text", "id": "colours", "label": "Colour options (comma separated)", "default": "1B, 27#, BUG, 613#" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wholesale Order Builder",
      "blocks": [
        { "type": "product_line", "settings": { "title": "Bone Straight Braiding Hair 30inch", "meta": "150g · Braiding Hair", "colours": "1B, 27#, BUG, 613#" } },
        { "type": "product_line", "settings": { "title": "French Curl 22inch", "meta": "150g · Curl Hair", "colours": "1B, 27#, BUG, 613#" } },
        { "type": "product_line", "settings": { "title": "Deep Wave Bulk 22inch", "meta": "100g · Bulk Hair", "colours": "1B, 27#, BUG, 613#" } },
        { "type": "product_line", "settings": { "title": "Premium Human Hair Bundles", "meta": "Raw Virgin · Pre-registration", "colours": "Natural Black, Custom" } }
      ]
    }
  ]
}
{% endschema %}
