<section class="section informal-page">
  <div class="eyebrow">
    <div class="eyebrow__line"></div>
    <span class="eyebrow__text">{{ section.settings.eyebrow }}</span>
  </div>
  <h1 class="section__title informal-page__title">{{ section.settings.title }} <em>{{ section.settings.title_italic }}</em></h1>
  {% if section.settings.lead != blank %}
    <p class="section__lead informal-page__lead">{{ section.settings.lead }}</p>
  {% endif %}
  <div class="informal-page__body">
    {{ section.settings.body }}
  </div>
</section>

{% schema %}
{
  "name": "Informal page",
  "tag": "section",
  "class": "section-informal-page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Information" },
    { "type": "text", "id": "title", "label": "Title", "default": "Page title." },
    { "type": "text", "id": "title_italic", "label": "Title (italic part)", "default": "Short subtitle." },
    { "type": "textarea", "id": "lead", "label": "Intro", "default": "This is informal placeholder copy. Replace it in the theme editor or in Shopify Admin when editing this page template." },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Add your full text here. You can use headings and lists from the rich text editor.</p>"
    }
  ],
  "presets": [{ "name": "Informal page" }]
}
{% endschema %}
