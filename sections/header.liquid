{% liquid
  assign header_logo = section.settings.logo_image
  if header_logo == blank
    assign header_logo = settings.logo
  endif
  assign header_logo_max = settings.logo_max_width | default: 200
  assign logo_alt = section.settings.logo_text | default: shop.name
  if section.settings.logo_sub != blank
    assign logo_alt = logo_alt | append: ' ' | append: section.settings.logo_sub
  endif
%}
{% capture header_account_icon %}
  <svg class="site-header__account-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M6 20v-1a4 4 0 014-4h4a4 4 0 014 4v1"/></svg>
{% endcapture %}
{% capture nav_contact_url %}{% render 'theme-contact-url' %}{% endcapture %}
{% assign nav_contact_url = nav_contact_url | strip %}
<div class="site-header-shell">
<div class="site-header">
  <a
    href="{{ routes.root_url }}"
    class="site-header__logo site-header__logo--image site-header__logo--with-wordmark"
    style="--header-logo-max: {{ header_logo_max }}px;"
  >
    {% if header_logo %}
      <img
        class="site-header__logo-img"
        src="{{ header_logo | image_url: width: 600 }}"
        srcset="
          {{ header_logo | image_url: width: 200 }} 200w,
          {{ header_logo | image_url: width: 300 }} 300w,
          {{ header_logo | image_url: width: 400 }} 400w,
          {{ header_logo | image_url: width: 600 }} 600w
        "
        sizes="(max-width: 480px) 55vw, {{ header_logo_max }}px"
        alt="{{ logo_alt | escape }}"
        width="{{ header_logo.width }}"
        height="{{ header_logo.height }}"
        loading="eager"
        fetchpriority="high"
      >
    {% else %}
      <img
        class="site-header__logo-img"
        src="{{ 'global-hair-direct-logo.png' | asset_url }}"
        alt="{{ logo_alt | escape }}"
        width="1024"
        height="682"
        loading="eager"
        fetchpriority="high"
      >
    {% endif %}
    <div class="site-header__logo-text">
      <span class="site-header__logo-main">{{ section.settings.logo_text | default: 'Global Hair Direct' | escape }}</span>
      {% assign logo_sub_display = section.settings.logo_sub | default: 'Nigeria' | strip %}
      {% if logo_sub_display != blank %}
        <span class="site-header__logo-sub">{{ logo_sub_display | escape }}</span>
      {% endif %}
    </div>
  </a>

  <nav class="site-header__nav">
    {% assign nav_menu = linklists[section.settings.menu] %}
    {% assign menu_has_collections_link = false %}
    {% for link in nav_menu.links %}
      {% assign nt_scan = link.title | downcase | strip %}
      {% if nt_scan contains 'coming soon' or nt_scan == 'home' %}
        {% continue %}
      {% endif %}
      {% if nt_scan contains 'collection' or nt_scan contains 'catalog' %}
        {% assign menu_has_collections_link = true %}
      {% endif %}
      {% if link.url contains '/collections' %}
        {% assign menu_has_collections_link = true %}
      {% endif %}
    {% endfor %}
    {% assign collections_nav_injected = false %}
    {% assign collections_path = routes.collections_url %}
    {% for link in nav_menu.links %}
      {% assign nav_title = link.title | downcase | strip %}
      {% if nav_title contains 'coming soon' %}
        {% continue %}
      {% endif %}
      {% if nav_title == 'home' %}
        {% continue %}
      {% endif %}
      {% assign is_contact_link = false %}
      {% if nav_title contains 'contact' %}
        {% assign is_contact_link = true %}
      {% endif %}
      {% if link.url == nav_contact_url %}
        {% assign is_contact_link = true %}
      {% endif %}
      {% unless menu_has_collections_link %}
        {% if is_contact_link %}
          {% unless collections_nav_injected %}
            <a
              href="{{ collections_path }}"
              class="site-header__nav-link {% if request.path == collections_path %}active{% endif %}"
            >
              Collections
            </a>
            {% assign collections_nav_injected = true %}
          {% endunless %}
        {% endif %}
      {% endunless %}
      {% assign display_title = link.title | strip %}
      {% assign display_title_upper = display_title | upcase %}
      {% if display_title == display_title_upper %}
        {% if nav_title == 'faq' %}
          {% assign display_title = 'FAQ' %}
        {% else %}
          {% assign words = display_title | downcase | split: ' ' %}
          {% capture display_title %}
            {% for word in words %}
              {{ word | capitalize }}{% unless forloop.last %} {% endunless %}
            {% endfor %}
          {% endcapture %}
          {% assign display_title = display_title | strip %}
        {% endif %}
      {% endif %}
      <a href="{{ link.url }}" class="site-header__nav-link {% if link.active %}active{% endif %}">
        {{ display_title }}
      </a>
    {% endfor %}
    {% unless menu_has_collections_link %}
      {% unless collections_nav_injected %}
        <a
          href="{{ collections_path }}"
          class="site-header__nav-link {% if request.path == collections_path %}active{% endif %}"
        >
          Collections
        </a>
      {% endunless %}
    {% endunless %}
  </nav>

  <div class="site-header__actions">
    <a href="{{ routes.search_url }}" class="site-header__search" aria-label="Search">
      <svg class="site-header__search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4.35-4.35"/></svg>
    </a>
    <a href="{{ routes.cart_url }}" class="site-header__cart" aria-label="{% if cart.item_count > 0 %}Cart, {{ cart.item_count }} items{% else %}Cart{% endif %}">
      <svg class="site-header__cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6h15l-1.5 9h-12L6 6z"/><path d="M6 6V4a2 2 0 012-2h8a2 2 0 012 2v2"/><circle cx="9" cy="20" r="1" fill="currentColor" stroke="none"/><circle cx="18" cy="20" r="1" fill="currentColor" stroke="none"/></svg>
      {% if cart.item_count > 0 %}
        <span class="site-header__cart-count">{{ cart.item_count }}</span>
      {% endif %}
    </a>
    {% if customer %}
      <a href="{{ routes.account_url }}" class="site-header__account" aria-label="Account">{{ header_account_icon }}</a>
    {% elsif shop.customer_accounts_enabled %}
      {% if settings.use_legacy_customer_auth %}
        <a href="{{ routes.storefront_login_url }}" class="site-header__account" aria-label="Log in" data-login-modal-open>{{ header_account_icon }}</a>
      {% else %}
        <a href="{{ routes.storefront_login_url }}" class="site-header__account" aria-label="Log in">{{ header_account_icon }}</a>
      {% endif %}
    {% endif %}
  </div>
</div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image (optional override)",
      "info": "Overrides the logo in Theme settings → Layout → Logo image. Leave empty to use the theme logo."
    },
    { "type": "text", "id": "logo_text", "label": "Brand name", "default": "Global Hair Direct" },
    { "type": "text", "id": "logo_sub", "label": "Tag line under brand name", "default": "Nigeria", "info": "Shown below the brand name in small caps (e.g. NIGERIA)." },
    {
      "type": "header",
      "content": "Navigation"
    },
    { "type": "link_list", "id": "menu", "label": "Navigation Menu", "default": "main-menu" }
  ]
}
{% endschema %}
