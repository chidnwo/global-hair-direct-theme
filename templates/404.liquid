<section class="section not-found">
  <div class="not-found__inner">
    <div class="eyebrow">
      <div class="eyebrow__line"></div>
      <span class="eyebrow__text">Error 404</span>
    </div>
    <h1 class="section__title not-found__title">This page <em>couldn’t be found.</em></h1>
    <p class="section__lead not-found__lead">
      The link may be broken or the page may have moved. Let’s get you back to the hair.
    </p>

    <form action="{{ routes.search_url }}" method="get" role="search" class="not-found__search">
      <input type="hidden" name="type" value="product">
      <label for="NotFoundSearch" class="not-found__search-label">Search the catalogue</label>
      <div class="not-found__search-row">
        <input
          id="NotFoundSearch"
          class="customer-form__input"
          type="search"
          name="q"
          placeholder="Search braiding, bulk, curls…"
          autocomplete="off"
        >
        <button type="submit" class="btn btn--navy">Search</button>
      </div>
    </form>

    <div class="not-found__actions">
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--gold">Shop the catalogue</a>
      <a href="{{ routes.root_url }}" class="btn not-found__btn-ghost">Back to home</a>
    </div>
  </div>
</section>
