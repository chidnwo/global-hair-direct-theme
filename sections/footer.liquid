<footer class="site-footer">
  <div class="site-footer__grid">
    <div>
      <div class="site-footer__brand">
        <div class="site-footer__logo-mark">
          <svg viewBox="0 0 16 16"><path d="M8 1C4.1 1 1 4.1 1 8s3.1 7 7 7 7-3.1 7-7-3.1-7-7-7zm0 3c.8 0 1.4.6 1.4 1.4S8.8 6.8 8 6.8 6.6 6.2 6.6 5.4 7.2 4 8 4zm0 8.5c-1.8 0-3.3-.8-4.3-2.1.6-.8 3-1.3 4.3-1.3s3.7.5 4.3 1.3c-1 1.3-2.5 2.1-4.3 2.1z"/></svg>
        </div>
        <span class="site-footer__brand-name">{{ section.settings.brand_name | default: shop.name }}</span>
      </div>
      <p class="site-footer__desc">{{ section.settings.desc | default: 'Quality hair supply for salon owners, distributors, and individual buyers across all 36 Nigerian states. Braiding hair, bulk hair, and premium extensions - delivered direct.' }}</p>
    </div>
    <div class="site-footer__col">
      <h5>Products</h5>
      <a href="#">Bone Straight 30inch</a>
      <a href="#">French Curl 22inch</a>
      <a href="#">Deep Wave Bulk</a>
      <a href="#">Colour Options</a>
      <a href="#">Coming Soon</a>
    </div>
    <div class="site-footer__col">
      <h5>Accounts</h5>
      <a href="#">Wholesale</a>
      <a href="#">Pre-Order</a>
      <a href="#">Salon Registration</a>
      <a href="#">Distributor Access</a>
      <a href="#">Referral Programme</a>
    </div>
    <div class="site-footer__col">
      <h5>Support</h5>
      <a href="#">WhatsApp Team</a>
      <a href="#">Track My Order</a>
      <a href="#">Return Policy</a>
      <a href="#">Terms of Sale</a>
      <a href="#">Privacy Policy</a>
    </div>
  </div>

  <div class="site-footer__bottom">
    <span class="site-footer__copy">© {{ 'now' | date: '%Y' }} {{ shop.name }} · All rights reserved · {{ section.settings.email }}</span>
    <div class="site-footer__payments">
      <span class="payment-badge">Paystack</span>
      <span class="payment-badge">Flutterwave</span>
      <span class="payment-badge">Bank Transfer</span>
      <span class="payment-badge">USSD</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand Name", "default": "Global Hair Direct Nigeria" },
    { "type": "textarea", "id": "desc", "label": "Brand Description" },
    { "type": "text", "id": "email", "label": "Contact Email", "default": "info@globalhairdirect.com.ng" }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
