{% liquid
  assign header_logo = section.settings.logo_image
  if header_logo == blank
    assign header_logo = settings.logo
  endif
  assign header_logo_max = settings.logo_max_width | default: 200
  assign logo_alt = section.settings.logo_text | default: shop.name
  if section.settings.logo_sub != blank
    assign logo_alt = logo_alt | append: ' ' | append: section.settings.logo_sub
  endif
%}
{% capture nav_contact_url %}{% render 'theme-contact-url' %}{% endcapture %}
{% assign nav_contact_url = nav_contact_url | strip %}
{% liquid
  assign nav_catalog_url = routes.all_products_collection_url
  if section.settings.catalog_collection != blank
    assign nav_catalog_collection = collections[section.settings.catalog_collection]
    if nav_catalog_collection != blank
      assign nav_catalog_url = nav_catalog_collection.url
    endif
  endif
  assign nav_collections_url = routes.collections_url
  assign nav_care_guide_url = '/pages/care-guide'
  if pages['care-guide'] != blank
    assign nav_care_guide_url = pages['care-guide'].url
  endif
  assign nav_wholesale_url = '/pages/wholesale'
  if pages.wholesale != blank
    assign nav_wholesale_url = pages.wholesale.url
  endif
  assign nav_order_url = '/pages/wholesale-order'
  if pages['wholesale-order'] != blank
    assign nav_order_url = pages['wholesale-order'].url
  endif
%}
<div class="site-header-shell">
<div class="site-header">
  <a
    href="{{ routes.root_url }}"
    class="site-header__logo site-header__logo--image site-header__logo--with-wordmark"
    style="--header-logo-max: {{ header_logo_max }}px;"
  >
    {% if header_logo %}
      <img
        class="site-header__logo-img"
        src="{{ header_logo | image_url: width: 600 }}"
        srcset="
          {{ header_logo | image_url: width: 200 }} 200w,
          {{ header_logo | image_url: width: 300 }} 300w,
          {{ header_logo | image_url: width: 400 }} 400w,
          {{ header_logo | image_url: width: 600 }} 600w
        "
        sizes="(max-width: 480px) 55vw, {{ header_logo_max }}px"
        alt="{{ logo_alt | escape }}"
        width="{{ header_logo.width }}"
        height="{{ header_logo.height }}"
        loading="eager"
        fetchpriority="high"
      >
    {% else %}
      <img
        class="site-header__logo-img"
        src="{{ 'global-hair-direct-logo.png' | asset_url }}"
        alt="{{ logo_alt | escape }}"
        width="1024"
        height="682"
        loading="eager"
        fetchpriority="high"
      >
    {% endif %}
    <div class="site-header__logo-text">
      <span class="site-header__logo-main">{{ section.settings.logo_text | default: 'Global Hair Direct' | escape }}</span>
      {% assign logo_sub_display = section.settings.logo_sub | default: 'Nigeria' | strip %}
      {% if logo_sub_display != blank %}
        <span class="site-header__logo-sub">{{ logo_sub_display | escape }}</span>
      {% endif %}
    </div>
  </a>

  <nav class="site-header__nav">
    <a
      href="{{ nav_catalog_url }}"
      class="site-header__nav-link {% if request.path == nav_catalog_url %}active{% endif %}"
    >
      Catalog
    </a>
    <a
      href="{{ nav_collections_url }}"
      class="site-header__nav-link {% if request.path == nav_collections_url %}active{% endif %}"
    >
      Collections
    </a>
    <a
      href="{{ nav_care_guide_url }}"
      class="site-header__nav-link {% if request.path == nav_care_guide_url %}active{% endif %}"
    >
      Care guide
    </a>
    <a
      href="{{ nav_wholesale_url }}"
      class="site-header__nav-link {% if request.path == nav_wholesale_url %}active{% endif %}"
    >
      Wholesale
    </a>
    <a
      href="{{ nav_order_url }}"
      class="site-header__nav-link {% if request.path == nav_order_url %}active{% endif %}"
    >
      Wholesale Order
    </a>
    <a
      href="{{ nav_contact_url }}"
      class="site-header__nav-link {% if request.path == nav_contact_url %}active{% endif %}"
    >
      Contact
    </a>
  </nav>

  <div class="site-header__actions">
    <a href="{{ routes.search_url }}" class="site-header__search" aria-label="Search">
      <svg class="site-header__search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-4.35-4.35"/></svg>
    </a>
    <a href="{{ nav_order_url }}" class="site-header__cta site-header__cta--order">Wholesale Order</a>
    <button
      type="button"
      class="site-header__menu-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="MobileMenu"
      data-mobile-menu-open
    >
      <svg class="site-header__menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/></svg>
    </button>
  </div>
</div>

<div class="site-header__mobile" id="MobileMenu" data-mobile-menu hidden>
  <div class="site-header__mobile-backdrop" data-mobile-menu-close></div>
  <nav class="site-header__mobile-panel" aria-label="Mobile">
    <div class="site-header__mobile-head">
      <span class="site-header__mobile-title">Menu</span>
      <button type="button" class="site-header__mobile-close" aria-label="Close menu" data-mobile-menu-close>
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12"/><path d="M18 6L6 18"/></svg>
      </button>
    </div>
    <a href="{{ nav_catalog_url }}" class="site-header__mobile-link">Catalog</a>
    <a href="{{ nav_collections_url }}" class="site-header__mobile-link">Collections</a>
    <a href="{{ nav_care_guide_url }}" class="site-header__mobile-link">Care guide</a>
    <a href="{{ nav_wholesale_url }}" class="site-header__mobile-link">Wholesale</a>
    <a href="{{ nav_contact_url }}" class="site-header__mobile-link">Contact</a>
    <div class="site-header__mobile-divider"></div>
    <a href="{{ nav_order_url }}" class="btn btn--gold btn--full site-header__mobile-cta">Wholesale Order</a>
  </nav>
</div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image (optional override)",
      "info": "Overrides the logo in Theme settings → Layout → Logo image. Leave empty to use the theme logo."
    },
    { "type": "text", "id": "logo_text", "label": "Brand name", "default": "Global Hair Direct" },
    { "type": "text", "id": "logo_sub", "label": "Tag line under brand name", "default": "Nigeria", "info": "Shown below the brand name in small caps (e.g. NIGERIA)." },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "paragraph",
      "content": "Primary links are fixed in order: Catalog, Collections, Care guide, Wholesale, Wholesale Order, Contact. The Wholesale Order button links to the /pages/wholesale-order page."
    },
    {
      "type": "collection",
      "id": "catalog_collection",
      "label": "Catalog collection",
      "info": "Optional. Defaults to the store’s All products collection if empty."
    }
  ]
}
{% endschema %}
